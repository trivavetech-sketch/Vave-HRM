# Port to run the NestJS server on
PORT=4000

# Environment (development or production)
NODE_ENV=development

# Database Connection (Supabase connection string or local Postgres)
# Example: postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vave_hrm
DB_SSL=false

# Redis Connection (Upstash Redis URL or local Redis)
# Example: rediss://default:xxxx@xxxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# JWT secret for authentication
JWT_SECRET=super-secret-development-key-change-this-in-production

# CORS Allowed Origins (comma-separated URLs)
CORS_ORIGINS=http://localhost:3000
